# Copy this file to .env for local development.
# Never commit a .env file with real secrets.

# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs that are allowed to use the bot
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USERS=your_user_id_here

# Webhook URL (backend only — leave unset for local polling mode)
# Set this to your backend public domain.
# The bot token path is appended automatically.
WEBHOOK_URL=https://your-backend-domain.com

# Cloudflare R2 credentials
# Create an API token in the R2 dashboard with Object Read & Write permissions
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY=your_access_key_here
R2_SECRET_KEY=your_secret_key_here
R2_BUCKET=your_bucket_name_here
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
